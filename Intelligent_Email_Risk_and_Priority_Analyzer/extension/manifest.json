{
  "manifest_version": 3,
  "name": "Gmail Phishing Risk Analyzer",
  "version": "1.0.0",
  "description": "Reads Gmail email content, sends it to backend API, and shows phishing risk.",
  "permissions": [],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
